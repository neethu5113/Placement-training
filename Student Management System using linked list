import java.util.Scanner;

class Student {
    int rollNo;
    String name;
    String dept;
    int m1, m2, m3;
    float avg;
    String grade;
    Student next;

    static Student head = null;

    Student(int rollNo, String name, String dept, int m1, int m2, int m3) {
        this.rollNo = rollNo;
        this.name = name;
        this.dept = dept;
        this.m1 = m1;
        this.m2 = m2;
        this.m3 = m3;
        calculate();
        this.next = null;
    }

    // Calculate average & grade
    void calculate() {
        avg = (m1 + m2 + m3) / 3.0f;

        if (avg >= 90) grade = "A+";
        else if (avg >= 75) grade = "A";
        else if (avg >= 60) grade = "B";
        else if (avg >= 50) grade = "C";
        else grade = "Fail";
    }

    // Add student
    static void addStudent(int rollNo, String name, String dept, int m1, int m2, int m3) {
        Student newStudent = new Student(rollNo, name, dept, m1, m2, m3);

        if (head == null) head = newStudent;
        else {
            Student temp = head;
            while (temp.next != null) temp = temp.next;
            temp.next = newStudent;
        }
        System.out.println("✅ Student Added");
    }

    // Display all
    static void displayStudents() {
        Student temp = head;

        if (temp == null) {
            System.out.println("No students");
            return;
        }

        while (temp != null) {
            System.out.println("\nRoll: " + temp.rollNo);
            System.out.println("Name: " + temp.name);
            System.out.println("Dept: " + temp.dept);
            System.out.println("Marks: " + temp.m1 + ", " + temp.m2 + ", " + temp.m3);
            System.out.println("Average: " + temp.avg);
            System.out.println("Grade: " + temp.grade);
            temp = temp.next;
        }
    }

    // Search
    static void searchStudent(int rollNo) {
        Student temp = head;

        while (temp != null) {
            if (temp.rollNo == rollNo) {
                System.out.println("Found: " + temp.name + " | Grade: " + temp.grade);
                return;
            }
            temp = temp.next;
        }
        System.out.println("Not Found");
    }

    // Delete
    static void deleteStudent(int rollNo) {
        if (head == null) return;

        if (head.rollNo == rollNo) {
            head = head.next;
            System.out.println("Deleted");
            return;
        }

        Student temp = head;

        while (temp.next != null && temp.next.rollNo != rollNo) {
            temp = temp.next;
        }

        if (temp.next != null) {
            temp.next = temp.next.next;
            System.out.println("Deleted");
        } else {
            System.out.println("Not Found");
        }
    }

    // Update marks
    static void updateMarks(int rollNo, int m1, int m2, int m3) {
        Student temp = head;

        while (temp != null) {
            if (temp.rollNo == rollNo) {
                temp.m1 = m1;
                temp.m2 = m2;
                temp.m3 = m3;
                temp.calculate();
                System.out.println("✅ Marks Updated");
                return;
            }
            temp = temp.next;
        }
        System.out.println("Student Not Found");
    }

    // MAIN METHOD
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int choice;

        do {
            System.out.println("\n1.Add 2.Display 3.Search 4.Delete 5.Update Marks 6.Exit");
            choice = sc.nextInt();

            switch (choice) {
                case 1:
                    System.out.print("Roll: ");
                    int r = sc.nextInt();
                    sc.nextLine();

                    System.out.print("Name: ");
                    String n = sc.nextLine();

                    System.out.print("Dept: ");
                    String d = sc.nextLine();

                    System.out.print("Marks (3 subjects): ");
                    int m1 = sc.nextInt();
                    int m2 = sc.nextInt();
                    int m3 = sc.nextInt();

                    addStudent(r, n, d, m1, m2, m3);
                    break;

                case 2:
                    displayStudents();
                    break;

                case 3:
                    System.out.print("Roll: ");
                    searchStudent(sc.nextInt());
                    break;

                case 4:
                    System.out.print("Roll: ");
                    deleteStudent(sc.nextInt());
                    break;

                case 5:
                    System.out.print("Roll: ");
                    int roll = sc.nextInt();
                    System.out.print("New Marks: ");
                    updateMarks(roll, sc.nextInt(), sc.nextInt(), sc.nextInt());
                    break;

                case 6:
                    System.out.println("Exit");
                    break;
            }

        } while (choice != 6);

        sc.close();
    }
}
